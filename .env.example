# ═══ XAU SCALPER BOT — Environment Variables ═══
# Copy to .env and fill in your keys

# Webhook security (must match the secret in Pine Script)
WEBHOOK_SECRET=change_me_to_random_string

# Finnhub (news + calendar) — free tier: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key

# Anthropic Claude (for reasoning generation) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key

# Telegram Bot — create via @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF
TELEGRAM_CHAT_ID=-1001234567890

# Server port
PORT=8000
